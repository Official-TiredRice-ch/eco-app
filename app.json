{
  "expo": {
    "name": "eco-app",
    "slug": "eco-app",
    "version": "1.0.9",
    "orientation": "portrait",
    "icon": "./assets/images/bombom.png",
    "scheme": "ecoapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/bombom.png",
      "resizeMode": "contain",
      "backgroundColor": "#007AFF"
    },
    "ios": {
      "supportsTablet": true,
      "statusBarStyle": "dark"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "supportsTablet": true,
        "foregroundImage": "./assets/images/bombom.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.tiredrice123.ecoapp",
      "navigationBar": {
        "visible": "false",
        "backgroundColor": "#00000000"
      },
       "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO"
      ],
      "statusBar": {
        "backgroundColor": "#007AFF",
        "translucent": false,
        "barStyle": "dark-content"
      },
      "softwareKeyboardLayoutMode": "pan",
      "usesCleartextTraffic": true,
      "networkSecurityConfig": "./android-network-security-config.xml"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/bombom.png"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      [
        "expo-system-ui",
        {
          "android": {
            "hideNavigationBar": true
          }
        }
      ],
      "./plugins/withAndroidNetworkSecurity.js",
      "./plugins/withHideNavigationBar.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dd80ee7a-b596-48dc-94cb-a4f68645a45b"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/dd80ee7a-b596-48dc-94cb-a4f68645a45b"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "tiredrice123"
  }
}
